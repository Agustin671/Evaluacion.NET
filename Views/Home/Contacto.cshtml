@{
    ViewData["Title"] = "Contacto";
}

<div class="card border-0 p-4 shadow-sm mt-2" style="border-radius: 16px; background: linear-gradient(135deg, #0f6e56, #1d9e75); color: white; position: relative; overflow: hidden;">

    <div style="position: absolute; bottom: -50px; right: -50px; width: 180px; height: 180px; background: rgba(255,255,255,0.05); border-radius: 50%;"></div>

    <h4 class="fw-bold mb-3" style="position: relative; z-index: 1;">Información Directa</h4>

    <p class="mb-4" style="color: #e1f5ee; font-size: 0.95rem; position: relative; z-index: 1;">
        Utiliza nuestros canales directos para verificar stock o realizar consultas con nuestros ejecutivos.
    </p>

    <div class="d-flex align-items-center mb-3" style="position: relative; z-index: 1;">
        <div style="width: 45px; height: 45px; background: rgba(255,255,255,0.15); border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-right: 15px;">
            <i class="bi bi-geo-alt-fill" style="font-size: 1.2rem;"></i>
        </div>
        <div>
            <span style="font-size: 0.75rem; color: #e1f5ee; font-weight: 600; letter-spacing: 0.5px;">UBICACIÓN</span>
            <div class="fw-bold" style="font-size: 1.1rem;">Av. Principal 123, Santiago</div>
        </div>
    </div>

    <div class="d-flex align-items-center mb-3" style="position: relative; z-index: 1;">
        <div style="width: 45px; height: 45px; background: rgba(255,255,255,0.15); border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-right: 15px;">
            <i class="bi bi-telephone-fill" style="font-size: 1.2rem;"></i>
        </div>
        <div>
            <span style="font-size: 0.75rem; color: #e1f5ee; font-weight: 600; letter-spacing: 0.5px;">TELÉFONO</span>
            <div class="fw-bold" style="font-size: 1.1rem;">+56 9 1234 5678</div>
        </div>
    </div>

    <div class="d-flex align-items-center" style="position: relative; z-index: 1;">
        <div style="width: 45px; height: 45px; background: rgba(255,255,255,0.15); border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-right: 15px;">
            <i class="bi bi-envelope-fill" style="font-size: 1.2rem;"></i>
        </div>
        <div>
            <span style="font-size: 0.75rem; color: #e1f5ee; font-weight: 600; letter-spacing: 0.5px;">CORREO</span>
            <div class="fw-bold" style="font-size: 1.1rem;">contacto@farmacia.cl</div>
        </div>
    </div>
</div>
