@{
    ViewData["Title"] = "Inicio";
}

<div class="d-flex justify-content-center align-items-center mt-2 mb-5">
    <div class="text-center w-100" style="background: linear-gradient(135deg, #0f6e56, #1d9e75); color: white; border-radius: 24px; padding: 4rem 2rem; box-shadow: 0 10px 30px rgba(15,110,86,0.15); position: relative; overflow: hidden;">

        <div style="position: absolute; top: -50px; right: -50px; width: 200px; height: 200px; background: rgba(255,255,255,0.1); border-radius: 50%;"></div>
        <div style="position: absolute; bottom: -30px; left: -30px; width: 150px; height: 150px; background: rgba(255,255,255,0.1); border-radius: 50%;"></div>

        <i class="bi bi-capsule-pill" style="font-size: 4.5rem; opacity: 0.9;"></i>
        <h1 class="display-5 fw-bold mt-3" style="letter-spacing: -1px;">Bienvenido a tu Farmacia</h1>
        <p class="lead mb-4 mx-auto" style="max-width: 600px; color: #e1f5ee; font-size: 1.1rem;">
            Salud y bienestar al alcance de un clic. Explora nuestro inventario y gestiona tus productos con el sistema más moderno y eficiente.
        </p>
        <a asp-controller="Medicamentos" asp-action="Index" class="btn bg-white text-success fw-bold shadow-sm" style="border-radius: 12px; padding: 0.8rem 2.5rem; font-size: 1.1rem; transition: transform 0.2s;">
            Ver Catálogo
        </a>
    </div>
</div>
