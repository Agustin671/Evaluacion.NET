@model IEnumerable<Farmacia.Models.Medicamentos>

@{
    ViewData["Title"] = "Catálogo Público";
}

<h2 class="text-primary mb-4">Nuestros Medicamentos</h2>

<div class="table-responsive shadow-sm rounded">
    <table class="table table-striped table-hover mb-0">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Descripción</th>
                <th>Precio</th>
                <th>Stock</th>
                <th>F. Fabricación</th>
                <th>F. Vencimiento</th>
                <th>Gramaje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.id)</td>
                    <td>@Html.DisplayFor(modelItem => item.nombre)</td>
                    <td>@Html.DisplayFor(modelItem => item.descripcion)</td>
                    <td class="text-success fw-bold">$@Html.DisplayFor(modelItem => item.valor)</td>
                    <td>@Html.DisplayFor(modelItem => item.cantidad) unid.</td>
                    <td>@item.fechaFabricacion.ToShortDateString()</td>
                    <td>@item.fechaCaducidad.ToShortDateString()</td>
                    <td>@Html.DisplayFor(modelItem => item.gramaje)</td>
                </tr>
            }
        </tbody>
    </table>
</div>