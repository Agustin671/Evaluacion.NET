@model IEnumerable<Farmacia.Models.Medicamentos>
@{
    ViewData["Title"] = "Catálogo Cliente";
}

<div class="d-flex align-items-center mb-4">
    <i class="bi bi-grid-fill me-3" style="font-size: 2rem; color: #1d9e75;"></i>
    <h2 class="m-0 fw-bold" style="color: #0f6e56; letter-spacing: -0.5px;">Catálogo de Productos</h2>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-2 g-4">
    @foreach (var item in Model)
    {
        <div class="col">
            <div class="card h-100 border-0" style="border-radius: 16px; background: white; box-shadow: 0 4px 15px rgba(0,0,0,0.04); transition: transform 0.2s;">

                <div class="card-header border-0 d-flex justify-content-center align-items-center" style="background: #e1f5ee; height: 120px; border-radius: 16px 16px 0 0;">
                    <i class="bi bi-prescription2" style="font-size: 3.5rem; color: #0f6e56; opacity: 0.8;"></i>
                </div>

                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h5 class="card-title fw-bold m-0" style="color: #2c2c2a; font-size: 1.25rem;">@item.nombre</h5>
                        <span class="badge" style="background: #1d9e75; border-radius: 8px;">@item.gramaje</span>
                    </div>

                    <p class="card-text mb-4" style="color: #888780; font-size: 0.9rem; line-height: 1.5; min-height: 40px;">
                        @(string.IsNullOrEmpty(item.descripcion) ? "Sin descripción disponible." : item.descripcion)
                    </p>

                    <div class="d-flex justify-content-between align-items-center pt-3" style="border-top: 1px dashed #e1f5ee;">
                        <div>
                            <span style="font-size: 0.75rem; color: #888780; display: block; font-weight: 600;">PRECIO</span>
                            <span class="fw-bold" style="color: #0f6e56; font-size: 1.3rem;">$@item.valor.ToString("N0")</span>
                        </div>
                        <div class="text-end">
                            <span style="font-size: 0.75rem; color: #888780; display: block; font-weight: 600;">DISPONIBLE</span>
                            <span class="fw-bold d-flex align-items-center" style="color: #2c2c2a;">
                                <i class="bi bi-box-seam me-1" style="color: #1d9e75;"></i> @item.cantidad u.
                            </span>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    }
</div>

<style>
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(15,110,86,0.12) !important;
    }
</style>
