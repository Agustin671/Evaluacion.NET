<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Farmacia</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light d-flex flex-column min-vh-100">

    <header class="bg-white border-bottom py-3 mb-3 shadow-sm text-center">
        <h1 class="text-primary m-0">Farmacia</h1>
    </header>

    <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-4">
        <div class="container">
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-center">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link text-dark fw-bold px-4" asp-controller="Home" asp-action="Index">Inicio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark fw-bold px-4" asp-controller="Medicamentos" asp-action="Index">Catálogo Cliente</a>
                    </li>
                    <li class="nav-item border-start border-end">
                        <a class="nav-link text-danger fw-bold px-4" asp-controller="Medicamentos" asp-action="Admin">Panel Admin</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark fw-bold px-4" asp-controller="Home" asp-action="Contacto">Contacto</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mb-5 flex-grow-1">
        <div class="row">
            <section class="col-md-8">
                <main role="main">
                    @RenderBody()
                </main>
            </section>

            <aside class="col-md-4">
                <div class="p-4 bg-white border rounded shadow-sm h-100">
                    <h4 class="text-primary">Información Útil</h4>
                    <hr />
                    <p><strong>Horario de atención:</strong><br />Lunes a Viernes de 08:00 a 20:00 hrs.</p>
                    <p><strong>Dudas y consultas:</strong><br />Llámanos al +56 9 1234 5678 para verificar stock antes de visitarnos.</p>
                </div>
            </aside>
        </div>
    </div>

    <footer class="border-top bg-white text-center py-4 text-muted mt-auto">
        <div class="container">
            &copy; 2026 - Sistema de Gestión de Farmacia - <a asp-controller="Home" asp-action="Contacto">Contacto</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
