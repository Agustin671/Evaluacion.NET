@{
    ViewData["Title"] = "Iniciar Sesión";
}

<style>
    .login-wrapper {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
    }

    .login-card {
        width: 100%;
        max-width: 440px;
        background: #ffffff;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(15, 110, 86, 0.15), 0 4px 20px rgba(0,0,0,0.08);
    }

    .login-header {
        background: linear-gradient(135deg, #0f6e56 0%, #1d9e75 60%, #5dcaa5 100%);
        padding: 2.5rem 2rem 2rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .login-header::before {
            content: '';
            position: absolute;
            top: -40px;
            right: -40px;
            width: 140px;
            height: 140px;
            border-radius: 50%;
            background: rgba(255,255,255,0.08);
        }

        .login-header::after {
            content: '';
            position: absolute;
            bottom: -30px;
            left: -20px;
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: rgba(255,255,255,0.06);
        }

    .login-icon {
        width: 64px;
        height: 64px;
        background: rgba(255,255,255,0.15);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
        border: 2px solid rgba(255,255,255,0.25);
    }

        .login-icon svg {
            width: 32px;
            height: 32px;
            fill: none;
            stroke: #ffffff;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

    .login-header h4 {
        color: #ffffff;
        font-size: 1.4rem;
        font-weight: 700;
        margin: 0 0 0.3rem;
        letter-spacing: -0.3px;
        position: relative;
        z-index: 1;
    }

    .login-header p {
        color: rgba(255,255,255,0.75);
        font-size: 0.875rem;
        margin: 0;
        position: relative;
        z-index: 1;
    }

    .login-body {
        padding: 2rem 2rem 2.5rem;
    }

    .login-label {
        font-size: 0.8rem;
        font-weight: 600;
        color: #444441;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        margin-bottom: 0.4rem;
        display: block;
    }

    .login-input-wrap {
        position: relative;
        margin-bottom: 1.25rem;
    }

        .login-input-wrap .icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #1d9e75;
            width: 18px;
            height: 18px;
        }

            .login-input-wrap .icon svg {
                width: 18px;
                height: 18px;
                fill: none;
                stroke: #1d9e75;
                stroke-width: 2;
                stroke-linecap: round;
                stroke-linejoin: round;
            }

    .login-input {
        width: 100%;
        padding: 0.75rem 1rem 0.75rem 2.75rem;
        border: 1.5px solid #e1f5ee;
        border-radius: 12px;
        font-size: 0.95rem;
        color: #2c2c2a;
        background: #f8fdfb;
        transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
        box-sizing: border-box;
    }

        .login-input:focus {
            outline: none;
            border-color: #1d9e75;
            background: #ffffff;
            box-shadow: 0 0 0 3px rgba(29, 158, 117, 0.12);
        }

        .login-input::placeholder {
            color: #b4b2a9;
        }

    .btn-login {
        width: 100%;
        padding: 0.85rem;
        background: linear-gradient(135deg, #0f6e56, #1d9e75);
        color: #ffffff;
        font-weight: 700;
        font-size: 1rem;
        border: none;
        border-radius: 12px;
        cursor: pointer;
        letter-spacing: 0.3px;
        transition: transform 0.15s, box-shadow 0.15s;
        box-shadow: 0 4px 15px rgba(15, 110, 86, 0.35);
    }

        .btn-login:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(15, 110, 86, 0.45);
        }

        .btn-login:active {
            transform: translateY(0);
        }

    .alert-danger {
        background: #fcebeb;
        border: 1px solid #f7c1c1;
        color: #791f1f;
        border-radius: 10px;
        padding: 0.75rem 1rem;
        font-size: 0.875rem;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .login-footer-text {
        text-align: center;
        margin-top: 1.5rem;
        font-size: 0.8rem;
        color: #888780;
    }

        .login-footer-text span {
            display: inline-block;
            width: 6px;
            height: 6px;
            background: #1d9e75;
            border-radius: 50%;
            vertical-align: middle;
            margin: 0 6px;
        }
</style>

<div class="login-wrapper">
    <div class="login-card">
        <div class="login-header">
            <div class="login-icon">
                <svg viewBox="0 0 24 24">
                    <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                </svg>
            </div>
            <h4>Acceso Administrativo</h4>
            <p>Ingresa tus credenciales para continuar</p>
        </div>

        <div class="login-body">
            @if (ViewBag.Error != null)
            {
                <div class="alert-danger">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10" />
                        <line x1="12" y1="8" x2="12" y2="12" />
                        <line x1="12" y1="16" x2="12.01" y2="16" />
                    </svg>
                    @ViewBag.Error
                </div>
            }

            <form asp-controller="Acceso" asp-action="Login" method="post">
                <div class="mb-3">
                    <label class="login-label">Usuario</label>
                    <div class="login-input-wrap">
                        <span class="icon">
                            <svg viewBox="0 0 24 24">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                <circle cx="12" cy="7" r="4" />
                            </svg>
                        </span>
                        <input type="text" name="usuario" class="login-input" placeholder="Ingrese su usuario" required autofocus />
                    </div>
                </div>

                <div class="mb-4">
                    <label class="login-label">Contraseña</label>
                    <div class="login-input-wrap">
                        <span class="icon">
                            <svg viewBox="0 0 24 24">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                            </svg>
                        </span>
                        <input type="password" name="clave" class="login-input" placeholder="Ingrese su contraseña" required />
                    </div>
                </div>

                <button type="submit" class="btn-login">Ingresar al Sistema</button>
            </form>

            <div class="login-footer-text">
                Farmacia<span></span>Sistema de Gestión<span></span>2026
            </div>
        </div>
    </div>
</div>
