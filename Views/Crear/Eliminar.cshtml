@model Farmacia.Models.Medicamentos

@{
    ViewBag.Title = "Eliminar Medicamento";
}

<div class="container mt-4">
    <h2 class="text-danger">Eliminar Medicamento</h2>
    <div class="alert alert-warning">
        <h4><i class="bi bi-exclamation-triangle"></i> ¡Atención!</h4>
        <p>¿Estás seguro de que deseas eliminar este registro? Esta acción no se puede deshacer.</p>
    </div>
    <hr />

    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-light">
            <h5 class="mb-0">Detalles del Medicamento a Eliminar</h5>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Nombre:</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.nombre)</dd>

                <dt class="col-sm-3">Descripción:</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.descripcion)</dd>

                <dt class="col-sm-3">Precio:</dt>
                <dd class="col-sm-9">$@Html.DisplayFor(model => model.valor)</dd>

                <dt class="col-sm-3">Stock Disponible:</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.cantidad) unidades</dd>

                <dt class="col-sm-3">Gramaje:</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.gramaje)</dd>
            </dl>
        </div>
    </div>

    @using (Html.BeginForm("Eliminar", "Crear", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        @Html.HiddenFor(model => model.id)

        <div class="form-actions no-color mt-3">
            <input type="submit" value="Sí, Eliminar Definitivamente" class="btn btn-danger" />
            @Html.ActionLink("Cancelar", "Index", "Medicamentos", null, new { @class = "btn btn-secondary ms-2" })
        </div>
    }
</div>